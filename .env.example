# ==============================================
# 邻里社区APP - 环境变量配置示例
# ==============================================
# 复制此文件为 .env 并填入真实值
# 复制命令: cp .env.example .env
# ==============================================

# ==============================================
# 应用配置
# ==============================================
VITE_APP_TITLE=邻里社区
VITE_APP_API_URL=/api
VITE_APP_VERSION=1.0.0

# ==============================================
# Cloudflare 配置（可选，用于 Wrangler CLI）
# ==============================================
# CLOUDFLARE_ACCOUNT_ID=your-account-id
# CLOUDFLARE_API_TOKEN=your-api-token

# ==============================================
# 数据库配置（如使用 D1）
# ==============================================
# D1_DATABASE_ID=your-d1-database-id

# ==============================================
# 开发环境配置
# ==============================================
# NODE_ENV=development
# VITE_DEBUG=true

# ==============================================
# 第三方服务配置（按需填写）
# ==============================================
# 微信小程序 AppID
# WX_APP_ID=your-wechat-app-id

# 地图服务 API Key（如使用腾讯地图）
# MAP_API_KEY=your-map-api-key

# 短信服务配置（如使用短信登录）
# SMS_API_KEY=your-sms-api-key
# SMS_TEMPLATE_ID=your-template-id
